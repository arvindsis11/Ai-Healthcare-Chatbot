# ============================================================
# AI Healthcare Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Variables without a default value are REQUIRED.
# Variables with a default value are OPTIONAL (the shown value
# is the default used when the variable is not set).
# ============================================================

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
# Required for LLM responses and symptom analysis.
# Leave blank to run in fallback (no-LLM) mode.
OPENAI_API_KEY=

# OpenAI model to use for chat completions.
# Default: gpt-3.5-turbo  (cheaper, faster)
# Other options: gpt-4, gpt-4o
OPENAI_MODEL=gpt-3.5-turbo

# ------------------------------------------------------------
# ChromaDB (Vector Database)
# ------------------------------------------------------------
# Directory where ChromaDB persists its data.
CHROMA_PERSIST_DIRECTORY=./embeddings

# Name of the ChromaDB collection storing healthcare documents.
CHROMA_COLLECTION_NAME=healthcare_docs

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=AI Healthcare Assistant

# Enable debug mode (verbose error messages, auto-reload).
# Set to false in production.
DEBUG=false

# ------------------------------------------------------------
# CORS — Allowed Frontend Origins
# ------------------------------------------------------------
# Comma-separated list of origins that may call the API.
# Example for production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# Maximum API requests per IP per minute.
RATE_LIMIT_PER_MINUTE=60

# Maximum size of a single HTTP request body in bytes (default 64 KB).
REQUEST_SIZE_LIMIT_BYTES=65536

# ------------------------------------------------------------
# Database (PostgreSQL) — Optional
# ------------------------------------------------------------
# When set, conversation history is persisted to PostgreSQL.
# When blank, an in-memory store is used (data lost on restart).
# Example: postgresql://user:password@localhost:5432/healthcare
DATABASE_URL=

# ------------------------------------------------------------
# Cache (Redis) — Optional
# ------------------------------------------------------------
# When set, the Redis cache is used for frequent query results.
# When blank, an in-memory TTL cache is used instead.
# Example: redis://localhost:6379/0
REDIS_URL=

# Cache TTL in seconds (how long query results are cached).
CACHE_TTL_SECONDS=300
