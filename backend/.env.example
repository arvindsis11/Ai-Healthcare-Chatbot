# AI Healthcare Assistant - Environment Variables

# OpenAI API Key (Required for STT and LLM)
OPENAI_API_KEY=your-openai-api-key-here

# ElevenLabs API Key (Required for TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ElevenLabs Voice ID (Optional - defaults to Rachel)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ElevenLabs Model ID (Optional - defaults to monolingual v1)
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Origins (for frontend)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000